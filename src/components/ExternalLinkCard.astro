---
import { LinkCard } from '@astrojs/starlight/components';
import { Icon } from '@astrojs/starlight/components';

// Wir nehmen alle Standard-Props der LinkCard entgegen
const props = Astro.props;
---

<div class="external-card-container">
  <LinkCard 
    {...props} 
    target="_blank" 
    rel="noopener noreferrer" 
  />
  <div class="external-indicator">
    <Icon name="external" size="1.2rem" />
  </div>
</div>

<style>
  .external-card-container {
    position: relative;
    display: block;
  }

  .external-indicator {
    position: absolute;
    top: 1rem;
    right: 1rem;
    pointer-events: none;
    color: var(--sl-color-gray-3);
    transition: transform 0.2s ease, color 0.3s ease;
  }

  .external-card-container:hover .external-indicator {
    color: var(--sl-color-accent-high);
    transform: translate(2px, -2px);
  }

  .external-card-container :global(.sl-link-card) {
    padding-inline-end: 3rem;
  }
</style>