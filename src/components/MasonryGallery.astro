---
// src/components/MasonryGallery.astro
import { Image } from 'astro:assets';
import 'photoswipe/style.css';

const { images } = Astro.props;
---

<div class="masonry-wrapper" id="pswp-gallery">
  {images.map((img) => (
    <figure class="masonry-item">
      <a 
        href={img.src.src} 
        data-pswp-width={img.src.width} 
        data-pswp-height={img.src.height} 
        target="_blank"
        class="pswp-link"
      >
        <Image 
          src={img.src} 
          alt={img.alt || ''} 
          width={400}
          quality="mid"
        />
        {img.caption && (
          <figcaption class="image-caption">
            {img.caption}
            {/* Verstecktes Element für die Lightbox-Caption */}
            <span class="pswp-caption-content" style="display:none;">{img.caption}</span>
          </figcaption>
        )}
      </a>
    </figure>
  ))}
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  function initPhotoSwipe() {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#pswp-gallery',
      children: 'a.pswp-link',
      pswpModule: () => import('photoswipe'),

      imageClickAction: 'close',
      tapAction: 'close',
    });

    lightbox.init();
  }

  // Unterstützung für Starlight (View Transitions / SPA-Navigation)
  initPhotoSwipe();
  document.addEventListener('astro:after-swap', initPhotoSwipe);
</script>

<style>
  .masonry-wrapper {
    column-count: 3;
    column-gap: 1.5rem;
    width: 100%;
  }

  .masonry-item {
    margin: 0 0 1.5rem;
    display: block;
    break-inside: avoid;
    border-radius: 12px;
    background: var(--sl-color-gray-6);
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    transition: transform 0.3s ease;
  }

  .masonry-item:hover {
    transform: translateY(-4px);
    border-color: var(--sl-color-accent);
  }

  .masonry-item img {
    width: 100%;
    height: auto;
    display: block;
    cursor: zoom-in;
  }

  .image-caption {
    padding: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
    border-top: 1px solid var(--sl-color-gray-5);
  }

  @media (max-width: 768px) { .masonry-wrapper { column-count: 2; } }
  @media (max-width: 480px) { .masonry-wrapper { column-count: 1; } }
</style>
