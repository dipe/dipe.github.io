---
// src/components/MasonryGallery.astro
import { Image, getImage } from 'astro:assets'; // getImage importiert
import 'photoswipe/style.css';

const { images } = Astro.props;

// Wir verarbeiten alle Bilder vor dem Rendern, um optimierte Versionen für die Lightbox zu erstellen
const optimizedImages = await Promise.all(
  images.map(async (img) => {
    const largeImage = await getImage({
      src: img.src,
      width: 1600,       // Begrenzt die Lightbox-Bilder auf eine vernünftige Maximalbreite
      format: 'webp',    // Liefert moderne WebP-Bilder an die Lightbox aus
      quality: 'high'
    });

    return {
      ...img,
      lightboxSrc: largeImage.src,
      lightboxWidth: largeImage.attributes.width,
      lightboxHeight: largeImage.attributes.height,
    };
  })
);
---

<div class="masonry-wrapper" id="pswp-gallery">
  {optimizedImages.map((img) => (
    <figure class="masonry-item">
      <a 
        href={img.lightboxSrc} {/* Nutzt jetzt die optimierte WebP-Großansicht */}
        data-pswp-width={img.lightboxWidth} {/* Nutzt die angepasste Breite */}
        data-pswp-height={img.lightboxHeight} {/* Nutzt die angepasste Höhe */}
        target="_blank"
        class="pswp-link"
      >
        <Image 
          src={img.src} 
          alt={img.alt || ''} 
          width={400}
          quality="mid"
        />
        {img.caption && (
          <figcaption class="image-caption">
            {img.caption}
            {/* Verstecktes Element für die Lightbox-Caption */}
            <span class="pswp-caption-content" style="display:none;">{img.caption}</span>
          </figcaption>
        )}
      </a>
    </figure>
  ))}
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  let lightbox = null;

  function initPhotoSwipe() {
    if (!document.querySelector('#pswp-gallery')) return;

    lightbox?.destroy();
    lightbox = new PhotoSwipeLightbox({
      gallery: '#pswp-gallery',
      children: 'a.pswp-link',
      pswpModule: () => import('photoswipe'),
      imageClickAction: 'close',
      tapAction: 'close',
      history: false,
    });
    lightbox.on('beforeOpen', () => {
      history.pushState({ pswp: true }, '', '#lightbox');

      const popstateHandler = () => {
        if (lightbox?.pswp) {
          lightbox.pswp.close();
        }
      };
      window.addEventListener('popstate', popstateHandler, { once: true });
    });
    lightbox.on('close', () => {
      if (location.hash === '#lightbox') {
        history.back();
      }
    });
    lightbox.init();
  }

  initPhotoSwipe();
  document.addEventListener('astro:page-load', initPhotoSwipe);
</script>

<style>
  .masonry-wrapper {
    column-count: 3;
    column-gap: 1.5rem;
    width: 100%;
  }

  .masonry-item {
    margin: 0 0 1.5rem;
    display: block;
    break-inside: avoid;
    border-radius: 0.5em;
    background: var(--sl-color-gray-6);
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    transition: transform 0.3s ease;
  }

  .masonry-item:hover {
    transform: translateY(-4px);
    border-color: var(--sl-color-accent);
  }

  .masonry-item img {
    width: 100%;
    height: auto;
    display: block;
    cursor: zoom-in;
  }

  .image-caption {
    padding: 0.75rem;
    font-size: 0.85rem;
    line-height: 1.4;
    color: var(--sl-color-gray-2);
    border-top: 1px solid var(--sl-color-gray-5);
  }

  @media (max-width: 768px) { .masonry-wrapper { column-count: 2; } }
  @media (max-width: 380px) { .masonry-wrapper { column-count: 1; } }
</style>